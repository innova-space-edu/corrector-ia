# ─── SUPABASE ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── OCR SERVICE (URL pública de Render) ──────────────────────────────────────
OCR_SERVICE_URL=https://corrector-ia-ocr.onrender.com

# ─── APP URL (para OpenRouter headers) ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://corrector-ia.vercel.app

# ─── AI PROVIDERS (el router usa el primero disponible, luego hace fallback) ──
#
# Orden de fallback:
#   1. Gemini 2.5 Flash  →  si falla
#   2. Groq Llama 3.3    →  si falla
#   3. OpenRouter :free  →  último recurso
#
# Puedes configurar solo 1 o los 3. Con los 3 el sistema nunca se cae.

# 1. Google AI Studio — GRATIS: 1,500 req/día, sin tarjeta
#    Obtener en: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=

# 2. Groq — GRATIS: 6,000 tokens/min, muy rápido (315 tok/seg)
#    Obtener en: https://console.groq.com → API Keys
GROQ_API_KEY=

# 3. OpenRouter — GRATIS: 30+ modelos con sufijo :free
#    Obtener en: https://openrouter.ai/keys
OPENROUTER_API_KEY=
