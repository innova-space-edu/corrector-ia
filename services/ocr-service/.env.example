# ─── SUPABASE ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── OCR SERVICE ──────────────────────────────────────────────────────────────
# URL del microservicio Python (NO va en Vercel — servidor aparte)
OCR_SERVICE_URL=http://localhost:8001

# ─── LLM PROVIDERS ────────────────────────────────────────────────────────────
# Primario: Google Gemini (gratis: 1,500 req/día)
# Obtener en: https://aistudio.google.com/app/apikey
AI_PROVIDER_API_KEY=
AI_PARSE_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions

# Alternativa Groq (gratis: 315 tok/seg)
# Obtener en: https://console.groq.com
GROQ_API_KEY=

# Alternativa OpenRouter (30+ modelos gratis con sufijo :free)
# Obtener en: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ─── AI ROUTER CONFIG ─────────────────────────────────────────────────────────
# Modelo a usar (opciones gratuitas):
# - gemini-2.5-flash-preview-05-20   (Google, 1,500 req/día)
# - llama-3.3-70b-versatile          (Groq, muy rápido)
# - deepseek/deepseek-r1:free        (OpenRouter)
# - qwen/qwen3-32b:free              (OpenRouter)
AI_MODEL=gemini-2.5-flash-preview-05-20

# ─── OCR SERVICE (Python) ─────────────────────────────────────────────────────
PORT=8001
